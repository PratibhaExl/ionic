
Creating a dynamic Slide Alert in Material-UI (now MUI) version 5.15.10 using hooks can be quite straightforward. MUI's Snackbar component works well for alert messages, and you can use it in combination with the Slide transition component to make alerts slide in and out. Here’s a simple example on how to dynamically create a slide alert using a custom hook:

First, ensure you have MUI installed in your project. If you haven't installed it yet, you can do so by running:

bash
Copy code
npm install @mui/material @emotion/react @emotion/styled
Next, let's create a custom hook useSlideAlert to manage the alert's visibility and content:

javascript
Copy code
import React, { useState, useCallback } from 'react';
import Snackbar from '@mui/material/Snackbar';
import MuiAlert from '@mui/material/Alert';
import Slide from '@mui/material/Slide';

// Helper function for the slide transition
function SlideTransition(props) {
  return <Slide {...props} direction="up" />;
}

// Custom Alert component for easier usage
const Alert = React.forwardRef(function Alert(props, ref) {
  return <MuiAlert elevation={6} ref={ref} variant="filled" {...props} />;
});

// Custom hook to use the slide alert
export function useSlideAlert() {
  const [open, setOpen] = useState(false);
  const [alertConfig, setAlertConfig] = useState({
    message: '',
    severity: 'info', // error, warning, info, success
  });

  const showAlert = useCallback((message, severity = 'info') => {
    setAlertConfig({ message, severity });
    setOpen(true);
  }, []);

  const handleClose = (event, reason) => {
    if (reason === 'clickaway') {
      return;
    }
    setOpen(false);
  };

  const renderAlert = () => (
    <Snackbar open={open} autoHideDuration={6000} onClose={handleClose} TransitionComponent={SlideTransition}>
      <Alert onClose={handleClose} severity={alertConfig.severity} sx={{ width: '100%' }}>
        {alertConfig.message}
      </Alert>
    </Snackbar>
  );

  return { showAlert, renderAlert };
}
You can then use this hook in your component like so:

javascript
Copy code
import React from 'react';
import Button from '@mui/material/Button';
import { useSlideAlert } from './path-to-your-hook/useSlideAlert'; // Adjust the path as necessary

function YourComponent() {
  const { showAlert, renderAlert } = useSlideAlert();

  return (
    <div>
      <Button onClick={() => showAlert('This is a success message!', 'success')}>Show Success Alert</Button>
      {renderAlert()}
    </div>
  );
}

export default YourComponent;
In this setup, useSlideAlert provides you with a showAlert function to display the alert and a renderAlert function that you need to include in your component's return statement to actually render the alert. The showAlert function takes a message and an optional severity level (by default 'info') as arguments.
