[
  {
    "useCaseId": "season-ticket-renewal-journey",
    "name": "Season Ticket Renewal Journey",
    "category": {
      "categoryId": "retention-renewals",
      "categoryName": "Retention & Renewals"
    },
    "journeyTable": {
      "journeyName": "Season Ticket Renewal Journey",
      "journeyGoal": "Drive season ticket renewals using phased engagement and urgency",
      "entryTrigger": "subscription_expiring",
      "journeyCategory": "Retention & Renewals",
      "totalDuration": "90 days",
      "exitClause": "Exit when renewal_completed OR at expiry date"
    },
    "entryCriteria": {
      "event": "subscription_expiring",
      "eventId": "evt_subscription_expiring_001",
      "conditions": [
        { "field": "daysToExpiry", "operator": "EQUALS", "value": 90 },
        { "field": "productType", "operator": "EQUALS", "value": "SEASON_TICKET" }
      ],
      "identity": { "primaryId": "customerId", "namespace": "ECID" },
      "audienceName": "Season_Ticket_Holders_Expiring"
    },
    "touchpoints": [
      {
        "tpId": "TP1",
        "label": "Day -90",
        "timing": { "relativeDay": -90, "description": "90 days before expiry" },
        "channel": "EMAIL",
        "messageTheme": "Early Bird Renewal – seat map visual, loyalty perks recap, early-bird pricing incentive",
        "cta": "Renew Now",
        "tracking": {
          "campaignId": "email_renewal_earlybird",
          "deliveryId": "del_email_renewal_001",
          "trackingEvents": ["email_sent", "email_open", "email_click"]
        },
        "personalization": ["firstName", "seatLocation", "loyaltyTier", "price"]
      }
    ],
    "journey": {
      "type": "scheduled",
      "timeReference": "expiryDate",
      "nodes": [
        { "id": "n1", "type": "ENTRY", "event": "subscription_expiring", "eventId": "evt_subscription_expiring_001" },
        { "id": "n2", "type": "MESSAGE", "tpId": "TP1" },
        { "id": "n7", "type": "EXIT" }
      ]
    },
    "exitConditions": [
      {
        "event": "renewal_completed",
        "eventId": "evt_renewal_completed_001",
        "action": "IMMEDIATE_EXIT"
      }
    ],
    "ajoConfig": {
      "frequencyCapping": { "enabled": true, "maxMessagesPerUser": 5, "timeWindowDays": 90 },
      "suppressionRules": [
        { "ruleId": "already_renewed", "condition": "renewal_completed == true" }
      ],
      "prioritization": { "priority": "HIGH" }
    },
    "tracking": {
      "globalEvents": ["journey_entered", "journey_exited", "renewal_completed"],
      "eventMapping": {
        "subscription_expiring": "evt_subscription_expiring_001",
        "renewal_completed": "evt_renewal_completed_001"
      }
    },
    "analytics": {
      "primaryKPI": "renewal_completed",
      "secondaryKPIs": ["email_open", "email_click"],
      "attribution": { "model": "multi_touch", "lookbackDays": 90 }
    },
    "version": "1.0",
    "status": "READY"
  },
  {
    "useCaseId": "season-ticket-onboarding",
    "name": "Season Ticket Holder Onboarding Journey",
    "category": {
      "categoryId": "onboarding-engagement",
      "categoryName": "Onboarding & Engagement"
    },
    "journeyTable": {
      "journeyName": "Season Ticket Holder Onboarding",
      "journeyGoal": "Activate new ticket holders, drive app adoption, and increase early engagement & revenue",
      "entryTrigger": "ticket_purchase_completed",
      "journeyCategory": "Onboarding & Engagement",
      "totalDuration": "21 days",
      "exitClause": "Exit after Day 21 OR if user becomes highly engaged"
    },
    "entryCriteria": {
      "event": "ticket_purchase_completed",
      "eventId": "evt_ticket_purchase_001",
      "conditions": [
        { "field": "productType", "operator": "EQUALS", "value": "SEASON_TICKET" }
      ],
      "identity": { "primaryId": "customerId", "namespace": "ECID" },
      "audienceName": "New_Season_Ticket_Holders"
    },
    "version": "1.0",
    "status": "READY"
  },
  {
    "useCaseId": "game-day-engagement",
    "name": "Game Day Fan Engagement Journey",
    "category": {
      "categoryId": "real-time-engagement",
      "categoryName": "Real-Time Engagement"
    },
    "journeyTable": {
      "journeyName": "Game Day Engagement",
      "journeyGoal": "Enhance live game experience, drive in-stadium engagement, and boost real-time revenue",
      "entryTrigger": "game_day_detected",
      "journeyCategory": "Real-Time Engagement",
      "totalDuration": "1 day",
      "exitClause": "Exit after post-game communication OR if user leaves stadium early"
    },
    "entryCriteria": {
      "event": "game_day_detected",
      "eventId": "evt_game_day_001",
      "conditions": [
        { "field": "ticketStatus", "operator": "EQUALS", "value": "VALID" }
      ],
      "identity": { "primaryId": "customerId", "namespace": "ECID" },
      "audienceName": "Game_Day_Attendees"
    },
    "version": "1.0",
    "status": "READY"
  }
]