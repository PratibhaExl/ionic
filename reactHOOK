import React, { useEffect } from 'react';

export function App(props) {
  return (
    <div className='App'>
      <h1>Hello React.</h1>
      <h2>Start editing to see some magic happen!</h2>

      <YourComponent />
    </div>
  );
}



import { useForm, Controller } from 'react-hook-form';

const YourComponent = () => {
  const { control, handleSubmit, setValue, watch } = useForm();

  // Array of field names
  const fields = [{id:'name'}, {id:'email'}, {id:'phone'}];

   const defaultValue={
      'name':'mahesh',
      'email':'ionic@gmail.com',
      'phone':'999999999'
   }

const getValueByFieldName = (fieldName) => {
  return defaultValue[fieldName] || ''; // Return the value of the given field name or an empty string if the field does not exist
};

   
  // Set default values for fields
  useEffect(() => {
    fields.forEach(fieldName => {
      setValue(fieldName.id, getValueByFieldName(fieldName.id)); // Set default value to empty string
    });
  }, [setValue, fields]);

  const onSubmit = data => {
    console.log(data); // Handle form submission
  };

  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      {fields.map(fieldName => (
        <div key={fieldName.id}>
          <label htmlFor={fieldName.id}>{fieldName.id}</label>
          <Controller
            name={fieldName.id}
            control={control}
            defaultValue="" // Set default value
            render={({ field }) => (
              <input
                {...field}
                type="text"
                onChange={e => field.onChange(e.target.value)} // Save field data onChange
              />
            
            )}
          />
        </div>
      ))}
      <button type="submit">Submit</button>
    </form>
  );
};

export default YourComponent;

